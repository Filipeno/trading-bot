# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control (it is git-ignored).

# ── Exchange (crypto) — Binance Testnet ──────────────────────────────────
# Get keys at: https://testnet.binance.vision/ (spot)
BINANCE_TESTNET_API_KEY=your_api_key_here
BINANCE_TESTNET_SECRET=your_secret_here

# ── LLM strategy (optional) ──────────────────────────────────────────────
# Mammouth.ai (OpenAI-compatible) — get from your Mammouth dashboard
MAMMOUTH_API_KEY=your_mammouth_key_here
# Anthropic (only if llm_provider = "anthropic")
ANTHROPIC_API_KEY=your_anthropic_key_here
